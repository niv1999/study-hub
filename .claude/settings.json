{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(git push --force)",
      "Bash(git push --force:*)",
      "Bash(git push -f)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)"
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
